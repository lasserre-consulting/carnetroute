# ── Carnet Route V2 — Backend — Variables d'environnement ────────────────────
#
# Copiez ce fichier en .env et renseignez les valeurs pour votre environnement.
# Ne committez jamais le fichier .env dans votre dépôt Git.
# Usage : docker run --env-file .env carnetroute-backend
#

# ── Serveur ──────────────────────────────────────────────────────────────────
# Port d'écoute de l'application (défaut : 8080)
PORT=8080

# Environnement d'exécution : dev | staging | production
APP_ENV=dev

# ── JWT ───────────────────────────────────────────────────────────────────────
# Clé secrète HMAC-256 pour signer les tokens. Minimum 32 caractères en prod.
JWT_SECRET=change-me-in-production-use-a-long-random-secret-key-here

# Durée de validité du token d'accès en secondes (défaut : 3600 = 1 heure)
# JWT_EXPIRES_IN_SECONDS=3600

# Durée de validité du token de rafraîchissement en secondes (défaut : 604800 = 7 jours)
# JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ── Base de données PostgreSQL ────────────────────────────────────────────────
# URL JDBC complète
DATABASE_URL=jdbc:postgresql://localhost:5432/carnetroute

# Utilisateur PostgreSQL
DATABASE_USER=postgres

# Mot de passe PostgreSQL
DATABASE_PASSWORD=your_secure_password_here

# Taille maximale du pool de connexions HikariCP (défaut : 10)
# DATABASE_POOL_SIZE=10

# ── Redis ─────────────────────────────────────────────────────────────────────
# URL de connexion Redis
REDIS_URL=redis://localhost:6379

# Si Redis requiert un mot de passe : redis://:password@host:6379
# REDIS_URL=redis://:your_redis_password@redis-host:6379

# ── NATS ──────────────────────────────────────────────────────────────────────
# URL du serveur NATS
NATS_URL=nats://localhost:4222

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées (séparées par une virgule dans la config HOCON)
# Configuré dans application.conf — surcharge via code si nécessaire.
# Exemple prod : https://app.carnetroute.fr

# ── Docker Compose (référence) ────────────────────────────────────────────────
# Lorsque vous utilisez Docker Compose, les URLs des services internes sont :
#   DATABASE_URL=jdbc:postgresql://db:5432/carnetroute
#   REDIS_URL=redis://redis:6379
#   NATS_URL=nats://nats:4222
